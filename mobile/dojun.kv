#:kivy 2.3.1
#:import dp kivy.metrics.dp

ScreenManager:
    MainScreen:
        name: "main"
    UpdateHistoryScreen:
        name: "history"
    IssueDetailScreen:
        name: "detail"


<MainScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.96, 0.97, 0.98, 1

        # ===== 상단 헤더 =====
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(108)
            md_bg_color: 0.13, 0.58, 0.92, 1

            FloatLayout:
                size_hint_y: None
                height: dp(56)

                MDTopAppBar:
                    id: topbar
                    title: ""
                    elevation: 0
                    md_bg_color: 0.13, 0.58, 0.92, 1
                    left_action_items: [["history", lambda x: app.go_history()]]
                    right_action_items: [["refresh", lambda x: app.refresh_issues()]]

                MDIcon:
                    id: update_dot
                    icon: "circle"
                    theme_text_color: "Custom"
                    text_color: 1, 0.2, 0.2, 1
                    opacity: 0
                    pos_hint: {"right": 0.98, "top": 0.80}
                    font_size: "12sp"
                    disabled: True

            MDLabel:
                text: "이번주 주요 쟁점 사항"
                font_name: "Nanum"
                font_size: "20sp"
                bold: True
                halign: "center"
                valign: "middle"
                size_hint_y: None
                height: dp(44)
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

        # ===== 커스텀 탭 바 =====
        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: dp(12), dp(8)
            spacing: dp(20)
            md_bg_color: 0.96, 0.97, 0.98, 1

            MDLabel:
                size_hint_x: 1

            MDFlatButton:
                id: tab_all
                text: "전체"
                font_name: "Nanum"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                md_bg_color: 0.13, 0.58, 0.92, 1
                on_release: root.set_tab("전체")

            MDFlatButton:
                id: tab_company
                text: "회사안"
                font_name: "Nanum"
                theme_text_color: "Custom"
                text_color: 0.25, 0.25, 0.25, 1
                md_bg_color: 1, 1, 1, 1
                on_release: root.set_tab("회사안")

            MDFlatButton:
                id: tab_union
                text: "조합안"
                font_name: "Nanum"
                theme_text_color: "Custom"
                text_color: 0.25, 0.25, 0.25, 1
                md_bg_color: 1, 1, 1, 1
                on_release: root.set_tab("조합안")

            MDLabel:
                size_hint_x: 1

        # ===== 메인 리스트 영역 =====
        MDBoxLayout:
            orientation: "vertical"
            padding: dp(8), dp(8), dp(8), dp(8)

            ScrollView:
                id: issue_scroll
                size_hint_y: 1
                do_scroll_x: False
                bar_width: dp(3)

                MDBoxLayout:
                    id: issue_list
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    padding: dp(8)
                    spacing: dp(12)

        # ===== 하단 버튼바 =====
        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: dp(12), 0
            spacing: dp(12)
            md_bg_color: 1, 1, 1, 1

            MDIconButton:
                icon: "history"
                theme_text_color: "Custom"
                text_color: 0.13, 0.58, 0.92, 1
                on_release: app.go_history()

            MDLabel:
                text: ""
                size_hint_x: 1

            MDIconButton:
                icon: "refresh"
                theme_text_color: "Custom"
                text_color: 0.13, 0.58, 0.92, 1
                on_release: app.refresh_issues()


<UpdateHistoryScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.96, 0.97, 0.98, 1

        MDTopAppBar:
            title: ""
            elevation: 0
            md_bg_color: 0.13, 0.58, 0.92, 1
            left_action_items: [["arrow-left", lambda x: app.go_main()]]

        MDLabel:
            text: "업데이트 내역"
            font_name: "Nanum"
            font_size: "20sp"
            bold: True
            halign: "center"
            size_hint_y: None
            height: dp(52)
            theme_text_color: "Custom"
            text_color: 0.1, 0.1, 0.1, 1

        ScrollView:
            do_scroll_x: False
            bar_width: dp(3)

            MDBoxLayout:
                id: history_container
                orientation: "vertical"
                size_hint_y: None
                padding: dp(16)
                spacing: dp(16)
                height: self.minimum_height


<IssueDetailScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.96, 0.97, 0.98, 1

        MDTopAppBar:
            title: "쟁점 상세"
            elevation: 0
            md_bg_color: 0.13, 0.58, 0.92, 1
            left_action_items: [["arrow-left", lambda x: app.go_main()]]

        ScrollView:
            do_scroll_x: False
            bar_width: dp(3)

            MDBoxLayout:
                id: detail_container
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: dp(16)
                spacing: dp(16)
